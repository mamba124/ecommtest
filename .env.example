# LLM API keys — provider is auto-detected from which key is present
# Priority: ANTHROPIC_API_KEY > GEMINI_API_KEY > Ollama (no key needed)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Redis cache
REDIS_HOST=redis
REDIS_PORT=6379

# Evaluation runner — address of the running RAG API
API_BASE_URL=http://localhost:8080

# Optional overrides
LOG_LEVEL=INFO
CONFIG_PATH=config.yaml
